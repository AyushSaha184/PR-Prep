# Required: Your Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the model used for complex diffs (default: gemini-1.5-pro)
PR_PREP_MODEL=gemini-2.5-pro

# Optional: Override the model used for simple diffs (default: gemini-1.5-flash)
PR_PREP_FLASH_MODEL=gemini-2.5-flash

